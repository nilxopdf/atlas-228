# ========== ФУНКЦИИ ==========
def log_command(user_id, username, command):
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log_message = f"{timestamp} | ID: {user_id} | User: @{username} | Command: {command}"
    logging.info(log_message)
    with open("bot_log.txt", "a", encoding="utf-8") as f:
        f.write(log_message + "\n")

def safe_reply(message, text, parse_mode=None):
    try:
        bot.reply_to(message, text, parse_mode=parse_mode)
    except Exception as e:
        logging.error(f"Ошибка отправки: {e}")
        try:
            bot.send_message(message.chat.id, text, parse_mode=parse_mode)
        except:
            pass

def generate_random_telegram_id():
    """Генерирует РАЗНЫЙ рандомный Telegram ID каждый раз"""
    prefixes = [1, 2, 3, 4, 5, 6, 7, 8, 9]
    prefix = random.choice(prefixes)
    # Разная длина каждый раз
    rest_length = random.randint(6, 10)
    rest = ''.join(random.choices('0123456789', k=rest_length))
    return int(f"{prefix}{rest}")

def generate_random_username():
    """Генерирует рандомный username для проверки"""
    prefixes = ["user", "telegram", "account", "profile", "chat", "id", "tg", "bot"]
    suffixes = ["123", "456", "789", "000", "777", "999", "random", "test"]
    
    username = random.choice(prefixes) + str(random.randint(100, 9999))
    if random.choice([True, False]):
        username += random.choice(suffixes)
    
    return username

def check_user_exists_via_api(user_id):
    """Проверка существования пользователя через API"""
    try:
        url = f"https://api.telegram.org/bot{BOT_TOKEN}/getChat"
        params = {"chat_id": user_id}
        
        response = requests.get(url, params=params, timeout=5)
        data = response.json()
        
        if data.get("ok"):
            chat_info = data.get("result", {})
            return {
                "exists": True,
                "id": chat_info.get("id"),
                "first_name": chat_info.get("first_name", "Неизвестно"),
                "last_name": chat_info.get("last_name", ""),
                "username": chat_info.get("username", "Нет username"),
                "type": chat_info.get("type", "private")
            }
        return {"exists": False}
            
    except Exception:
        return {"exists": False}

def find_random_real_user():
    """Поиск РАЗНОГО реального пользователя каждый раз"""
    # Разные стратегии поиска
    strategies = [
        "random_id",      # Рандомные ID
        "sequential_id",  # ID из определенного диапазона
        "username"        # Поиск по username
    ]
    
    strategy = random.choice(strategies)
    max_attempts = 40
    
    for attempt in range(max_attempts):
        if strategy == "random_id":
            # Полностью рандомный ID
            test_id = generate_random_telegram_id()
            result = check_user_exists_via_api(test_id)
            
            if result["exists"] and test_id not in found_ids_cache:
                found_ids_cache.add(test_id)
                # Очищаем кэш если слишком большой
                if len(found_ids_cache) > 100:
                    found_ids_cache.clear()
                return {"id": test_id, "info": result, "method": "random_id"}
        
        elif strategy == "username":
            # Поиск по username
            test_username = generate_random_username()
            try:
                url = f"https://api.telegram.org/bot{BOT_TOKEN}/getChat"
                params = {"chat_id": f"@{test_username}"}
                response = requests.get(url, params=params, timeout=5)
                data = response.json()
                
                if data.get("ok") and data.get("result"):
                    chat_info = data["result"]
                    user_id = chat_info.get("id")
                    
                    if user_id and user_id not in found_ids_cache:
                        found_ids_cache.add(user_id)
                        if len(found_ids_cache) > 100:
                            found_ids_cache.clear()
                        return {
                            "id": user_id,
                            "info": {
                                "exists": True,
                                "id": user_id,
                                "first_name": chat_info.get("first_name", "Неизвестно"),
                                "last_name": chat_info.get("last_name", ""),
                                "username": test_username,
                                "type": chat_info.get("type", "private")
                            },
                            "method": "username"
                        }
            except:
                pass
        
        # Небольшая задержка чтобы не флудить
        time.sleep(0.05)
    
    # Если не нашли - пробуем другой метод
    if strategy != "random_id":
        return find_random_real_user()
    
    return None

