@bot.message_handler(commands=['checkid'])
def check_by_id(message):
    """Проверка конкретного ID"""
    user = message.from_user
    log_command(user.id, user.username, '/checkid')
    
    parts = message.text.split()
    if len(parts) < 2:
        safe_reply(message, "❌ Использование: /checkid 123456789")
        return
    
    user_id = parts[1]
    status_msg = bot.reply_to(message, f"🔍 Проверяю ID: {user_id}...")
    
    try:
        result = check_user_exists_via_api(user_id)
        
        if result["exists"]:
            response = f"""✅ **ПОЛЬЗОВАТЕЛЬ СУЩЕСТВУЕТ!**

📌 **ID:** `{result['id']}`
👤 **Имя:** {result['first_name']}
🔤 **Username:** @{result['username']}

🔗 **Ссылка:** tg://user?id={user_id}"""
        else:
            response = f"❌ **ПОЛЬЗОВАТЕЛЬ НЕ НАЙДЕН!**\n\nID: `{user_id}`"
        
        bot.edit_message_text(response, status_msg.chat.id, status_msg.message_id, parse_mode='Markdown')
        
    except Exception as e:
        bot.edit_message_text(f"❌ Ошибка: {str(e)[:100]}", status_msg.chat.id, status_msg.message_id)

